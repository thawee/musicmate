<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="@dimen/dimen_72_dp"
    android:layout_marginStart="@dimen/dimen_8_dp"
    android:layout_marginEnd="@dimen/dimen_8_dp"
    android:background="@drawable/selector_item"
    android:paddingTop="@dimen/dimen_4_dp"
    android:paddingBottom="@dimen/dimen_4_dp">

    <!-- Cover Art -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/item_image_coverart"
        android:layout_width="@dimen/dimen_72_dp"
        android:layout_height="@dimen/dimen_72_dp"
        android:layout_marginStart="@dimen/dimen_4_dp"
        android:layout_marginEnd="@dimen/dimen_8_dp"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedImageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:src="@tools:sample/avatars" />

    <!-- Text Column -->
    <LinearLayout
        android:id="@+id/item_title_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/shape_item_background"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintStart_toEndOf="@id/item_image_coverart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Title -->
        <TextView
            android:id="@+id/item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:fontFamily="@font/sfthonburi_bold"
            android:text="@{title}"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium.Emphasized"
            android:textColor="?attr/colorOnSurface"
            tools:text="Hi-Res Audio" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/item_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:fontFamily="@font/sfthonburi_regular"
            android:layout_marginTop="2dp"
            android:text="@{subtitle}"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="24-bit • 96–384 kHz" />

        <!-- Statistic -->
        <TextView
            android:id="@+id/item_statistic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:singleLine="true"
            android:fontFamily="@font/sfthonburi_regular"
            android:layout_marginTop="2dp"
            android:text="@{statistic}"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:text="628 Songs" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>