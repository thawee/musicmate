<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_dark_blur"
    android:elevation="8dp"
    android:layout_margin="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_dialog_header_gradient"
        android:padding="14dp">

        <ImageView
            android:id="@+id/title_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="TODO"
            android:src="@drawable/ic_round_audio_file_24"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/title"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="@string/lossless_verifier"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ProgressBar
            android:id="@+id/analysis_progress_spinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone"
            tools:visibility="visible" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="@dimen/dimen_2_dp"
        android:paddingLeft="@dimen/dimen_8_dp"
        android:paddingRight="@dimen/dimen_8_dp"
        android:paddingBottom="@dimen/dimen_8_dp">

        <TextView
            android:id="@+id/filename"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/grey400"
            android:layout_gravity="center"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="start"
            android:padding="@dimen/dimen_4_dp"
            tools:text="14 - ขอบใจที่หาเจอ.flac" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/dimen_2_dp"
            android:weightSum="2"
            android:padding="@dimen/dimen_4_dp">
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                tools:ignore="UselessParent">
                <TextView
                    android:id="@+id/format_labels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/grey400"
                    android:alpha="0.7"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="5"
                    android:ellipsize="start"
                    android:layout_marginBottom="8dp"
                    android:paddingEnd="@dimen/dimen_8_dp"
                    tools:text="FORMAT" />
                <TextView
                    android:id="@+id/format_values"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:alpha="0.7"
                    android:textSize="12sp"
                    android:maxLines="5"
                    android:gravity="end"
                    android:layout_marginBottom="8dp"
                    tools:text="-" />

            </LinearLayout>
            <LinearLayout
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                tools:ignore="UselessParent">
                <TextView
                    android:id="@+id/analytics_labels"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/grey400"
                    android:alpha="0.7"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="6"
                    android:ellipsize="start"
                    android:layout_marginBottom="8dp"
                    android:paddingEnd="@dimen/dimen_8_dp"
                    tools:text="ANALYTICS"
                    tools:ignore="RtlSymmetry" />
                <TextView
                    android:id="@+id/analytics_values"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:alpha="0.7"
                    android:textSize="12sp"
                    android:maxLines="6"
                    android:gravity="end"
                    android:layout_marginBottom="8dp"
                    tools:text="-" />

            </LinearLayout>
                <!--
        <TextView
            android:id="@+id/format"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:alpha="0.7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="5"
            android:ellipsize="start"
            android:layout_marginBottom="8dp"
            tools:text="14 - ขอบใจที่หาเจอ.flac" />
            <TextView
                android:id="@+id/analytics"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:alpha="0.7"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="5"
                android:ellipsize="start"
                android:layout_marginBottom="8dp"
                tools:text="14 - ขอบใจที่หาเจอ.flac" />
                -->
        </LinearLayout>
        <TextView
            android:id="@+id/quality_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_gravity="center"
            android:textColor="@color/grey200"
            android:textSize="11sp"
            android:maxLines="2"
            android:textStyle="italic"
            tools:text="Verified Lossless" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_4_dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#1A1A1A"
            android:layout_marginBottom="@dimen/dimen_4_dp">

            <apincer.android.mmate.ui.view.AspectRatioPhotoView
                android:id="@+id/spectrum_view"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:scaleType="fitXY" />
        </androidx.cardview.widget.CardView>

        <!--
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/dimen_2_dp"
            android:layout_marginBottom="@dimen/dimen_8_dp"
            android:gravity="center">

                <TextView
                    android:id="@+id/quality_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/grey200"
                    android:textSize="14sp"
                    android:maxLines="2"
                    android:textStyle="italic"
                    tools:text="Verified Lossless" />
        </LinearLayout>
        -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_ok"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ok"
                android:backgroundTint="@color/teal_200"
                android:textColor="@color/black" />
        </LinearLayout>
    </LinearLayout>
    <View
        android:layout_width="wrap_content"
        android:layout_height="@dimen/dimen_2_dp"
        android:background="@color/grays_charcoal"
        android:layout_marginStart="@dimen/dimen_24_dp"
        android:layout_marginEnd="@dimen/dimen_24_dp"
        android:layout_marginTop="@dimen/dimen_12_dp"
        android:layout_marginBottom="@dimen/dimen_8_dp"/>
</LinearLayout>